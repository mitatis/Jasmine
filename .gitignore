# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/apps/api/.pytest_cache/
/apps/api/.coverage

# next.js
/.next/
/apps/*/.next/
/out/
/apps/*/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local object/file storage
/apps/api/.local-storage/

# python
__pycache__/
*.py[cod]
/.venv/
/apps/api/.venv/
